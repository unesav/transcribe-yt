              </p>
            </div>
            <div class="feature-card-lg">
              <div class="feature-icon-lg">⬇️</div>
              <h3>
                <%= t.downloadFormats %>
              </h3>
              <p>
                <%= t.downloadFormatsDesc %>
              </p>
            </div>
            <div class="feature-card-lg">
              <div class="feature-icon-lg">⏱️</div>
              <h3>
