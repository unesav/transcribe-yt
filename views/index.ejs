<!DOCTYPE html>
<html lang="<%= lang %>" <% if (dir==="rtl" ) { %> dir="rtl"<% } %>>

  <head>
    <!-- Google Tag Manager -->
    <script>(function (w, d, s, l, i) {
        w[l] = w[l] || []; w[l].push({
          'gtm.start':
            new Date().getTime(), event: 'gtm.js'
        }); var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
            'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-M56CTZXQ');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <%= t.title %>
    </title>
    <meta name="description" content="<%= t.metaDescription %>" />
    <link rel="canonical" href="<%= canonical %>" />
    <%- hreflangTags %>

      <!-- Open Graph -->
      <meta property="og:type" content="website" />
      <meta property="og:title" content="<%= t.title %>" />
      <meta property="og:description" content="<%= t.metaDescription %>" />
      <meta property="og:url" content="<%= canonical %>" />
      <meta property="og:site_name" content="TranscribeYoutubeVideo" />

      <!-- Twitter Card -->
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content="<%= t.title %>" />
      <meta name="twitter:description" content="<%= t.metaDescription %>" />

      <!-- Preconnect for performance -->
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet" />
      <link rel="stylesheet" href="/style.css" />
      <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

      <!-- Schema: WebSite + SearchAction -->
      <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "TranscribeYoutubeVideo",
    "url": "https://transcribeyoutubevideo.com/",
    "description": "Free YouTube transcript generator. Extract, copy, and download video transcripts instantly.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://transcribeyoutubevideo.com/?v={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

      <!-- Schema: Organization -->
      <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "TranscribeYoutubeVideo",
    "url": "https://transcribeyoutubevideo.com/",
    "logo": "https://transcribeyoutubevideo.com/logo.png",
    "sameAs": []
  }
  </script>

      <!-- Schema: FAQPage -->
      <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "<%= t.faq1Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, completely free. There are no hidden fees, no account required, and no usage limits. Just paste a YouTube URL and extract the transcript instantly."
        }
      },
      {
        "@type": "Question",
        "name": "<%= t.faq2Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our tool automatically detects and extracts the original language of any YouTube video. It works with 100+ languages including English, Spanish, French, German, Portuguese, Arabic, Hindi, Japanese, Korean, Chinese, and many more."
        }
      },
      {
        "@type": "Question",
        "name": "<%= t.faq3Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can download transcripts in three formats: SRT (SubRip Subtitle) for video editing, VTT (WebVTT) for web players, and TXT (plain text) for notes and documents."
        }
      },
      {
        "@type": "Question",
        "name": "<%= t.faq4Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You can copy the transcript with or without timestamps. The 'Copy with timestamps' button includes MM:SS timestamps alongside each paragraph. Download formats like SRT and VTT also include precise timing data."
        }
      },
      {
        "@type": "Question",
        "name": "<%= t.faq5Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can extract transcripts from any public YouTube video that has captions enabled — either manually uploaded by the creator or auto-generated by YouTube. Videos with captions disabled by the creator cannot be transcribed."
        }
      },
      {
        "@type": "Question",
        "name": "<%= t.faq6Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our tool automatically checks for creator-uploaded captions first, then falls back to YouTube's auto-generated captions (ASR). It always prioritizes the video's original language to give you the most accurate transcript."
        }
      },
      {
        "@type": "Question",
        "name": "<%= t.faq7Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. There are no limits on video length or the number of transcripts you can extract. You can transcribe videos of any duration as many times as you need."
        }
      },
      {
        "@type": "Question",
        "name": "<%= t.faq8Q %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No installation required. TranscribeYoutubeVideo runs entirely in your browser. Just visit the website, paste a YouTube URL, and get your transcript instantly."
        }
      }
    ]
  }
  </script>
      <!-- Prevent FOUC: apply saved theme before paint -->
      <script>(() => { const t = localStorage.getItem('theme'); if (t) document.documentElement.setAttribute('data-theme', t); })()</script>
      <script>window.__LANG__ = '<%= lang %>'; window.__T__ = <% - JSON.stringify(t) %>;</script>
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M56CTZXQ" height="0" width="0"
        style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- ===== HOME VIEW ===== -->
    <div id="home-view" class="view active">
      <div class="hero-bg">
        <nav class="nav">
          <a href="/" class="nav-brand">
            <img src="/favicon.svg" alt="TranscribeYoutubeVideo" class="nav-logo" width="28" height="28" />
            <span class="nav-title">TranscribeYoutubeVideo</span>
          </a>
          <div class="nav-actions">
            <!-- Language Switcher -->
            <div class="lang-switcher-wrapper">
              <button class="lang-switcher-btn" aria-label="<%= t.langSwitcher %>" title="<%= t.langSwitcher %>">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M2 12h20" />
                  <path
                    d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
                <span class="lang-switcher-label">
                  <%= langNativeName %>
                </span>
                <svg class="lang-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <div class="lang-dropdown">
                <% for (const [code, info] of Object.entries(availableLangs)) { %>
                  <a href="<%= code === 'en' ? '/' : '/' + code %>"
                    class="lang-option<%= code === lang ? ' active' : '' %>" data-lang="<%= code %>">
                    <%= info.name %>
                  </a>
                  <% } %>
              </div>
            </div>

            <button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark mode" title="Toggle theme">
              <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
              </svg>
              <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5" />
                <line x1="12" y1="1" x2="12" y2="3" />
                <line x1="12" y1="21" x2="12" y2="23" />
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                <line x1="1" y1="12" x2="3" y2="12" />
                <line x1="21" y1="12" x2="23" y2="12" />
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
              </svg>
            </button>
          </div><!-- /nav-actions -->
        </nav>

        <!-- HERO -->
        <section class="hero" id="hero">
          <h1 class="hero-headline">
            <%= t.heroHeadline %> <span class="accent">
                <%= t.heroAccent %>
              </span>
          </h1>
          <p class="hero-subtitle">
            <%= t.heroSubtitle %>
          </p>

          <div class="input-group">
            <div class="input-wrapper">
              <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </svg>
              <input type="text" id="url-input" placeholder="<%= t.inputPlaceholder %>" autocomplete="off"
                spellcheck="false" aria-label="YouTube video URL" />
            </div>
            <button id="extract-btn" class="btn-primary">
              <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
                <path d="m9 10 2 2 4-4" />
              </svg>
              <span>
                <%= t.extractTranscript %>
              </span>
            </button>
          </div>

          <div id="home-error" class="error-message hidden"></div>

          <div class="features-grid">
            <div class="feature-card">
              <div class="feature-icon">⚡</div>
              <h3>
                <%= t.instantExtraction %>
              </h3>
              <p>
                <%= t.instantExtractionDesc %>
              </p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">📋</div>
              <h3>
                <%= t.oneClickCopy %>
              </h3>
              <p>
                <%= t.oneClickCopyDesc %>
              </p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">🔍</div>
              <h3>
                <%= t.searchFilter %>
              </h3>
              <p>
                <%= t.searchFilterDesc %>
              </p>
            </div>
          </div>
        </section>
      </div><!-- /hero-bg -->

      <!-- HOW IT WORKS -->
