    <!-- ===== RESULTS VIEW ===== -->
    <div id="results-view" class="view">
      <nav class="nav">
        <div class="nav-brand">
          <button id="back-btn" class="btn-ghost" title="<%= t.backToHome %>">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m15 18-6-6 6-6" />
            </svg>
          </button>
          <a href="/" class="nav-brand-link">
            <img src="/favicon.svg" alt="TranscribeYoutubeVideo" class="nav-logo" width="28" height="28" />
            <span class="nav-title">TranscribeYoutubeVideo</span>
          </a>
        </div>
        <div class="nav-input-wrapper">
          <input type="text" id="nav-url-input" placeholder="<%= t.pasteUrl %>" autocomplete="off" spellcheck="false" />
          <button id="nav-extract-btn" class="btn-primary btn-sm">
            <%= t.extract %>
          </button>
        </div>
        <div class="nav-actions">
          <!-- Language Switcher -->
          <div class="lang-switcher-wrapper">
            <button class="lang-switcher-btn" aria-label="<%= t.langSwitcher %>" title="<%= t.langSwitcher %>">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              <span class="lang-switcher-label">
                <%= langNativeName %>
              </span>
              <svg class="lang-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                stroke-width="2">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </button>
            <div class="lang-dropdown">
              <% for (const [code, info] of Object.entries(availableLangs)) { %>
                <a href="<%= code === 'en' ? '/' : '/' + code %>"
                  class="lang-option<%= code === lang ? ' active' : '' %>" data-lang="<%= code %>">
                  <%= info.name %>
                </a>
                <% } %>
            </div>
          </div>
          <button class="theme-toggle" id="theme-toggle-results" aria-label="Toggle theme" title="Toggle theme">
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5" />
              <line x1="12" y1="1" x2="12" y2="3" />
              <line x1="12" y1="21" x2="12" y2="23" />
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
              <line x1="1" y1="12" x2="3" y2="12" />
              <line x1="21" y1="12" x2="23" y2="12" />
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
            </svg>
          </button>
        </div><!-- /nav-actions -->
      </nav>

      <main class="results-layout">
        <!-- Left: Video Info -->
        <aside class="video-panel">
          <div class="video-card">
            <div class="video-thumbnail-wrapper">
              <img id="video-thumbnail" src="" alt="Video thumbnail" loading="lazy" />
              <a id="video-play-link" href="#" target="_blank" rel="noopener" class="play-overlay">
                <svg viewBox="0 0 68 48" width="68" height="48">
                  <path
                    d="M66.5 7.7c-.8-2.9-2.5-5.4-5.4-6.2C55.8.1 34 0 34 0S12.2.1 6.9 1.5C4 2.3 2.3 4.8 1.5 7.7.1 13 0 24 0 24s.1 11 1.5 16.3c.8 2.9 2.5 5.4 5.4 6.2C12.2 47.9 34 48 34 48s21.8-.1 27.1-1.5c2.9-.8 4.6-3.3 5.4-6.2C67.9 35 68 24 68 24s-.1-11-1.5-16.3z"
                    fill="#FF0000" />
                  <path d="m28 33 18-9-18-9z" fill="#FFF" />
                </svg>
              </a>
            </div>
            <h2 id="video-title" class="video-title">Loading...</h2>
            <div class="video-meta">
              <span id="video-author" class="video-author"></span>
            </div>
            <div class="video-ids">
              <div class="id-chip">
                <span class="id-label">
                  <%= t.videoIdLabel %>:
                </span>
                <span id="display-video-id" class="id-value"></span>
              </div>
            </div>
          </div>
        </aside>

        <!-- Center: Transcript -->
        <section class="transcript-panel">
          <!-- Action Buttons Bar -->
          <div class="action-bar">
            <button id="copy-plain-btn" class="action-btn action-btn-accent">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg>
              Copy
            </button>
            <button id="copy-ts-btn" class="action-btn action-btn-accent">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              Copy with timestamps
            </button>
            <div class="dropdown" id="download-dropdown">
              <button class="action-btn action-btn-accent dropdown-toggle" id="download-btn">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                <%= t.download %>
                  <svg class="chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                    stroke-width="2">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
              </button>
              <div class="dropdown-menu" id="download-menu">
                <button class="dropdown-item" data-format="srt">.SRT</button>
                <button class="dropdown-item" data-format="vtt">.VTT</button>
                <button class="dropdown-item" data-format="txt">.TXT</button>
              </div>
            </div>
          </div>

          <div class="transcript-toolbar">
            <div class="search-wrapper">
              <svg class="search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor"
                stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </svg>
              <input type="text" id="search-input" placeholder="<%= t.searchTranscript %>"
                aria-label="Search transcript" />
            </div>
          </div>

          <div id="transcript-container" class="transcript-container">
            <!-- Transcript lines will be injected here -->
          </div>

          <div class="transcript-footer">
            <span id="word-count">Word Count: 0</span>
            <span class="separator">·</span>
            <span id="char-count">Character count: 0</span>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div class="footer-inner">
          <div class="footer-grid">
            <div class="footer-brand">
              <div class="footer-logo">
                <img src="/favicon.svg" alt="TranscribeYoutubeVideo" width="24" height="24" />
                <span class="footer-name">TranscribeYoutubeVideo</span>
              </div>
              <p class="footer-tagline">
                <%= t.footerTagline %>
              </p>
            </div>
            <div class="footer-links">
              <h4>
                <%= t.footerProduct %>
              </h4>
              <ul>
                <li><a href="<%= langPrefix %>/#how-it-works">
                    <%= t.footerHowItWorks %>
                  </a></li>
                <li><a href="<%= langPrefix %>/#features">
                    <%= t.footerFeatures %>
                  </a></li>
                <li><a href="<%= langPrefix %>/#formats">
                    <%= t.footerFormats %>
                  </a></li>
                <li><a href="<%= langPrefix %>/#faq">
                    <%= t.footerFAQ %>
                  </a></li>
              </ul>
            </div>
            <div class="footer-links">
              <h4>
                <%= t.footerCompany %>
              </h4>
              <ul>
                <li><a href="/about">
                    <%= t.footerAbout %>
                  </a></li>
                <li><a href="/contact">
                    <%= t.footerContact %>
                  </a></li>
              </ul>
            </div>
            <div class="footer-links">
              <h4>
                <%= t.footerLegal %>
              </h4>
              <ul>
                <li><a href="/privacy-policy">
                    <%= t.footerPrivacy %>
                  </a></li>
                <li><a href="/terms">
                    <%= t.footerTerms %>
                  </a></li>
              </ul>
            </div>
          </div>
          <div class="footer-bottom">
            <p class="footer-disclaimer">
              <%= t.footerDisclaimer %>
            </p>
            <p class="footer-copyright">
              <%= t.footerCopyright %>
            </p>
          </div>
        </div>
      </footer>
    </div>

    <!-- ===== LOADING OVERLAY ===== -->
    <div id="loading-overlay" class="loading-overlay hidden">
      <div class="loading-content">
        <div class="spinner"></div>
        <p class="loading-text">
          <%= t.extracting %>
        </p>
      </div>
    </div>

    <!-- ===== TOAST ===== -->
    <div id="toast" class="toast hidden">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 6 9 17l-5-5" />
      </svg>
      <span>
        <%= t.copiedClipboard %>
      </span>
    </div>

    <!-- Scroll reveal animation -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => observer.observe(el));
      });
    </script>
    <!-- Theme toggle -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggleTheme = () => {
          const html = document.documentElement;
          const current = html.getAttribute('data-theme');
          const next = current === 'light' ? 'dark' : 'light';
          if (next === 'dark') {
            html.removeAttribute('data-theme');
            localStorage.removeItem('theme');
          } else {
            html.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
          }
        };
        document.querySelectorAll('.theme-toggle').forEach(btn => {
          btn.addEventListener('click', toggleTheme);
        });
      });
    </script>
    <script src="/app.js"></script>
  </body>

</html>