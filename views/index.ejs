          <p class="section-note">
            <%= t.langSectionNote %>
          </p>
        </div>
      </section>

      <!-- FAQ -->
      <section class="section section-alt reveal" id="faq">
        <div class="section-inner">
          <h2 class="section-title">
            <%= t.faqTitle %>
          </h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary class="faq-question">Is this YouTube transcript tool free?</summary>
              <div class="faq-answer">
                <p>Yes, completely free. There are no hidden fees, no account required, and no usage limits. Just paste
                  a
                  YouTube URL and extract the transcript instantly.</p>
              </div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">What languages are supported?</summary>
              <div class="faq-answer">
                <p>Our tool automatically detects and extracts the original language of any YouTube video. It works with
                  100+ languages including English, Spanish, French, German, Portuguese, Arabic, Hindi, Japanese,
                  Korean,
                  Chinese, and many more.</p>
              </div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">What download formats are available?</summary>
              <div class="faq-answer">
                <p>You can download transcripts in three formats: <strong>SRT</strong> (SubRip Subtitle) for video
                  editing, <strong>VTT</strong> (WebVTT) for web players, and <strong>TXT</strong> (plain text) for
                  notes
                  and documents.</p>
              </div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">Does the transcript include timestamps?</summary>
              <div class="faq-answer">
                <p>Yes. You can copy the transcript with or without timestamps. The "Copy with timestamps" button
                  includes
                  MM:SS timestamps alongside each paragraph. Download formats like SRT and VTT also include precise
                  timing
                  data.</p>
              </div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">Can I extract transcripts from any YouTube video?</summary>
              <div class="faq-answer">
                <p>You can extract transcripts from any public YouTube video that has captions enabled — either manually
                  uploaded by the creator or auto-generated by YouTube. Videos with captions disabled by the creator
                  cannot
                  be transcribed.</p>
              </div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">How does auto-generated caption detection work?</summary>
              <div class="faq-answer">
                <p>Our tool automatically checks for creator-uploaded captions first, then falls back to YouTube's
                  auto-generated captions (ASR). It always prioritizes the video's original language to give you the
                  most
                  accurate transcript.</p>
              </div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">Is there a limit on video length or number of transcripts?</summary>
              <div class="faq-answer">
                <p>No. There are no limits on video length or the number of transcripts you can extract. You can
                  transcribe
                  videos of any duration as many times as you need.</p>
              </div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">Do I need to install any software?</summary>
              <div class="faq-answer">
                <p>No installation required. TranscribeYoutubeVideo runs entirely in your browser. Just visit the
                  website,
                  paste a YouTube URL, and get your transcript instantly.</p>
              </div>
            </details>
          </div>
        </div>
      </section>

